# Minimal Doxygen config for Ensure.hpp. Undocumented settings fall back to
# Doxygen's built-in defaults -- see https://www.doxygen.nl/manual/config.html.

PROJECT_NAME           = "Ensure"
PROJECT_BRIEF           = "Assertion, caution, and conditional-throw utilities with std::format-style messages"

OUTPUT_DIRECTORY       = docs
INPUT                  = Ensure.hpp README.md
USE_MDFILE_AS_MAINPAGE = README.md

RECURSIVE              = NO
EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO
JAVADOC_AUTOBRIEF      = YES

GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_TREEVIEW      = YES
DISABLE_INDEX          = NO
FULL_SIDEBAR           = NO
FULL_PATH_NAMES        = NO
SOURCE_BROWSER         = NO
HTML_COLORSTYLE        = LIGHT
HTML_EXTRA_STYLESHEET  = doxygen-awesome-css/doxygen-awesome.css \
                         doxygen-awesome-css/doxygen-awesome-sidebar-only.css

GENERATE_LATEX         = NO
GENERATE_XML           = NO
GENERATE_MAN           = NO
GENERATE_RTF           = NO

QUIET                  = NO
WARN_IF_UNDOCUMENTED   = NO
